#!/usr/bin/env sh

# Git hooks may run with a minimal PATH (especially from GUI apps on macOS).
export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.volta/bin:$HOME/.asdf/shims:$PATH"

if ! command -v pnpm >/dev/null 2>&1; then
	# Load nvm lazily when pnpm is not already available.
	if [ -s "$HOME/.nvm/nvm.sh" ]; then
		. "$HOME/.nvm/nvm.sh"
	fi
fi

if command -v pnpm >/dev/null 2>&1; then
	PNPM="pnpm"
elif command -v corepack >/dev/null 2>&1; then
	PNPM="corepack pnpm"
else
	echo "pre-commit: pnpm not found. Ensure pnpm or Corepack is installed and available to Git hooks." >&2
	exit 1
fi

# Run formatting/lint/integrity + preview generation
$PNPM run precommit || exit 1

# Stage only generated assets updated by scripts so commit includes them
git add preview/ src/symbol-icon-theme.json README.md
